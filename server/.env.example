# GhostLink Signaling Server Configuration

# HTTP server port (health checks, TURN credentials)
PORT_HTTP=3000

# WebSocket signaling server port
PORT_WS=3001

# TURN server shared secret for HMAC-SHA1 credential generation
# IMPORTANT: Change this in production!
TURN_SECRET=ghostlink-turn-secret-change-me

# TURN server URL (leave empty to use STUN-only)
# Example: turn:turn.example.com:3478
TURN_SERVER_URL=

# TURN credential TTL in seconds (default: 86400 = 24 hours)
TURN_TTL=86400

# Allowed WebSocket origins (comma-separated, * for all)
# Example: https://ghostlink.app,https://localhost:5173
ALLOWED_ORIGINS=*
